rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasUserProfile() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return hasUserProfile()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : "customer";
    }

    function isStaff() {
      return userRole() in ["moderator", "admin", "developer"];
    }

    function ownerMutableKeys() {
      return [
        "courses",
        "lastActivity",
        "completedTopics",
        "forcePasswordChange",
        "lastPasswordChangeAt",
        "updatedAt",
        "agreementAccepted",
        "agreementAcceptedAt"
      ];
    }

    function ownerUpdateAllowed() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(ownerMutableKeys());
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if false;
      allow delete: if false;
      allow update: if isOwner(userId) && ownerUpdateAllowed();

      match /quizResults/{resultId} {
        allow read, write: if isOwner(userId);
      }

      // Certificates registry (per user). Issued ONLY server-side via the Admin
      // SDK (which bypasses these rules), so they can never be forged or altered
      // from the client. The owner — and staff — may read their own records;
      // clients may never write.
      match /certificates/{certificateId} {
        allow read: if isOwner(userId) || isStaff();
        allow write: if false;
      }

      // Learning analytics event stream + aggregates. Written ONLY server-side
      // via the Admin SDK (POST /api/analytics?action=track), read ONLY server
      // side by staff endpoints. Students may never read or write analytics —
      // not even their own — so no learner can enumerate or forge activity.
      match /events/{eventId} {
        allow read, write: if false;
      }
      match /analytics/{docId} {
        allow read, write: if false;
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }

    match /activityLogs/{logId} {
      allow create: if isSignedIn() &&
        request.resource.data.userEmail is string &&
        request.resource.data.action is string;
      allow read: if isStaff();
      allow update, delete: if false;
    }

    // Admin audit trail. Written server-side via the Admin SDK only (which
    // bypasses these rules); clients may never write. Staff may read for review.
    match /adminAuditLogs/{logId} {
      allow read: if isStaff();
      allow write: if false;
    }

    // Global certificate registry + monotonic number counters. Written and read
    // ONLY by the Admin SDK (server). The verification page and admin search go
    // through server endpoints, never directly — so clients have no access and
    // sequential numbers cannot be enumerated from the client.
    match /certificateRegistry/{certificateNumber} {
      allow read, write: if false;
    }

    match /counters/{counterId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
